{
  "name": "taskflow-frontend",
  "version": "1.2.0",
  "private": true,
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.6",
    "focus-trap-react": "^11.0.4",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
  "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
  "lint:fix": "npm run lint -- --fix",
  "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "verify:modifiers": "node ../scripts/verify-modifiers.js",
    "verify:nodanger": "node ../scripts/verify-no-danger.js",
    "verify:completed-opacity": "node ../scripts/verify-no-opacity-completed.js",
  "build:stats": "cross-env GENERATE_SOURCEMAP=true react-scripts build",
  "analyze": "source-map-explorer 'build/static/js/*.js' --html analyze.html",
    "ci": "npm run lint && npm run verify:nodanger && npm run verify:completed-opacity && npm test --workspaces=false",
    "release:mobile": "node scripts/release-mobile.js",
    "verify:build": "node scripts/verify-build.js",
    "bundle:budget": "node scripts/bundle-budget.js",
    "size:snapshot": "npm run build && node ../scripts/size-snapshot.js",
    "analyze:build": "npm run build && source-map-explorer 'build/static/js/*.js' --html build/bundle-report.html",
    "analyze:json": "npm run build && source-map-explorer 'build/static/js/*.js' --json build/bundle-report.json",
    "android:copy": "npx cap copy android",
    "android:open": "npx cap open android",
    "android:build:debug": "cd android && gradlew assembleDebug",
    "android:build:release": "cd android && gradlew assembleRelease",
    "android:build:bundle": "cd android && gradlew bundleRelease",
    "android:install:debug": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:install:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "android:deploy:debug": "npm run release:mobile && npm run android:copy && npm run android:build:debug && npm run android:install:debug",
    "test": "react-scripts test",
    "test:ci": "cross-env CI=true react-scripts test --watchAll=false",
    "test:a11y": "react-scripts test --testPathPattern=a11y",
    "test:e2e": "playwright test",
    "test:mobile": "playwright test --config=playwright.mobile.config.js",
    "test:mobile:ui": "playwright test --config=playwright.mobile.config.js --ui",
    "evidence": "node scripts/collect-evidence.js",
    "wait-and-collect": "wait-on http://localhost:3000 && node scripts/collect-evidence.js",
    "evidence:all": "concurrently -k -s first -n APP,EVID \"npm:start\" \"npm:wait-and-collect\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@playwright/test": "^1.54.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "jest-axe": "^9.0.0",
    "playwright": "^1.54.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react-scripts": "^5.0.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.0",
    "wait-on": "^7.2.0",
    "web-vitals": "^3.0.0"
  }
}
